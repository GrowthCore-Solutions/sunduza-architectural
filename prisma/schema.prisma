generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── ADMIN ────────────────────────────────────────────────────────────────────

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── BOOKING ──────────────────────────────────────────────────────────────────
// Status flow: new → contacted → in_review → confirmed → completed | cancelled

model Booking {
  id          String   @id @default(cuid())
  name        String
  email       String
  phone       String
  service     String
  location    String
  description String
  meetingDate String
  budget      String?
  status      String   @default("new")
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── CONTACT MESSAGE ──────────────────────────────────────────────────────────

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ─── PROJECT (Portfolio) ──────────────────────────────────────────────────────

model Project {
  id               String   @id @default(cuid())
  title            String
  shortDescription String
  imageUrl         String
  category         String
  featured         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ─── TESTIMONIAL ──────────────────────────────────────────────────────────────

model Testimonial {
  id         String   @id @default(cuid())
  clientName String
  review     String
  rating     Int
  featured   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
