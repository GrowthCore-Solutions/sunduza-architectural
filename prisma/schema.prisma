// Sunduza Architectural & Projects — Prisma Schema v2.0
// Provider  : PostgreSQL on Neon (S5.1, S5.4)
// ORM       : Prisma 5 (S5.9)
// Auth      : NextAuth v5 database sessions via @auth/prisma-adapter (S3.5)
// Migrations: prisma migrate dev (dev) | prisma migrate deploy (CI/prod) (S5.59)
// Locked    : design-docs/SUNDUZA_LOCKED_DESIGN.md — Part 3

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
}

// S5.9 — Booking lifecycle: PENDING → CONTACTED → CONFIRMED → COMPLETED | REJECTED
enum BookingStatus {
  PENDING
  CONTACTED
  CONFIRMED
  COMPLETED
  REJECTED
}

// Audit trail actions — append-only (S2.62)
enum AuditAction {
  LOGIN_SUCCESS
  LOGIN_FAILURE
  LOGOUT
  BOOKING_CREATE
  BOOKING_STATUS_UPDATE
  BOOKING_DELETE
  PROJECT_CREATE
  PROJECT_UPDATE
  PROJECT_DELETE
  CONTACT_MESSAGE_CREATE
  CONTACT_MESSAGE_READ
  SETTINGS_UPDATE
}

// ─── USER ─────────────────────────────────────────────────────────────────────
// Single admin identity. NextAuth adapter-compatible fields included.
// Password: bcrypt hash at cost factor from BCRYPT_ROUNDS env var (S3.3)
// Session: database sessions via sessions table, never JWT (S3.5)

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  password       String
  name           String?
  role           UserRole  @default(ADMIN)
  // Account lockout fields (S3.4 — Layer 2 rate limiting)
  failedAttempts Int       @default(0) @map("failed_attempts")
  lockedUntil    DateTime? @map("locked_until")
  // NextAuth adapter required fields
  emailVerified  DateTime? @map("email_verified")
  image          String?
  // Audit timestamps (S5.10)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  sessions     Session[]
  accounts     Account[]
  auditLogs    AuditLog[]
  siteSettings SiteSettings[]

  @@index([deletedAt])
  @@map("users")
}

// ─── ACCOUNT ──────────────────────────────────────────────────────────────────
// NextAuth Prisma adapter — OAuth providers (future v2 use, Credentials-only now)

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refreshToken      String? @map("refresh_token")
  accessToken       String? @map("access_token")
  expiresAt         Int?    @map("expires_at")
  tokenType         String? @map("token_type")
  scope             String?
  idToken           String? @map("id_token")
  sessionState      String? @map("session_state")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

// ─── SESSION ──────────────────────────────────────────────────────────────────
// Database-backed sessions — deleting a row revokes the session instantly (S3.5)
// One per device per login. Cleaned up on logout or expiry.

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expires])
  @@map("sessions")
}

// ─── VERIFICATION TOKEN ───────────────────────────────────────────────────────
// NextAuth adapter — magic link / email verification (not used in v1)

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── BOOKING ──────────────────────────────────────────────────────────────────
// Core lead entity. Island entity — no FK to User or Project (S5.1).
// Booking is anonymous: visitors submit without an account.
// POPIA: consent_given + consent_given_at required (BR-009).
// Lead score: stored computed value, calculated on creation (S5.19 denormalization).
// UTM: all 5 dimensions captured from query params (marketing attribution).

model Booking {
  id String @id @default(cuid())

  // Visitor contact (denormalized — no Visitor entity in v1)
  name  String
  email String
  phone String

  // Project details
  // service values: house_planning | arch_drawings | drafting_services | dev_project_planning
  service     String
  location    String
  description String
  meetingDate DateTime? @map("meeting_date")
  budget      String?

  // Lead management
  status    BookingStatus @default(PENDING)
  leadScore Int?          @map("lead_score")
  adminNotes String?      @map("admin_notes")

  // POPIA legal compliance (BR-009)
  consentGiven   Boolean   @default(false) @map("consent_given")
  consentGivenAt DateTime? @map("consent_given_at")

  // Marketing attribution — 5 UTM dimensions (not a repeating group)
  utmSource   String? @map("utm_source")
  utmMedium   String? @map("utm_medium")
  utmCampaign String? @map("utm_campaign")
  utmTerm     String? @map("utm_term")
  utmContent  String? @map("utm_content")
  referrerUrl String? @map("referrer_url")
  landingPage String? @map("landing_page")

  // Technical metadata
  userAgent String? @map("user_agent")
  ipAddress String? @map("ip_address")

  // Audit timestamps (S5.10)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // Indexes — admin list queries (status + date, status + lead score)
  @@index([status, createdAt(sort: Desc)])
  @@index([status, leadScore(sort: Desc)])
  @@index([email])
  @@index([createdAt(sort: Desc)])
  @@index([utmSource])
  @@map("bookings")
}

// ─── PROJECT ──────────────────────────────────────────────────────────────────
// Portfolio items — managed entirely by admin CRUD.
// imagePath: must be /images/projects/filename.ext format.
// sortOrder: admin-controlled display order (lower = first).
// isFeatured: show on homepage preview (max 3 recommended).

model Project {
  id          String    @id @default(cuid())
  title       String
  description String
  imagePath   String    @map("image_path")
  category    String?
  sortOrder   Int       @default(0) @map("sort_order")
  isFeatured  Boolean   @default(false) @map("is_featured")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  testimonials Testimonial[]

  @@index([isFeatured, sortOrder])
  @@index([sortOrder])
  @@index([category])
  @@map("projects")
}

// ─── TESTIMONIAL ──────────────────────────────────────────────────────────────
// Client reviews. Optional FK to Project — NULL = general business review.
// isActive: show/hide without deleting (soft visibility toggle).
// rating: 1–5, enforced at application layer (Zod) + DB CHECK in migration.

model Testimonial {
  id         String    @id @default(cuid())
  clientName String    @map("client_name")
  review     String
  rating     Int?
  projectId  String?   @map("project_id")
  isActive   Boolean   @default(true) @map("is_active")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([isActive])
  @@index([projectId])
  @@map("testimonials")
}

// ─── CONTACT MESSAGE ──────────────────────────────────────────────────────────
// General inquiries — separate from bookings.
// No UTM capture — not a tracked conversion event in v1.
// read/readAt: admin inbox read-state tracking.

model ContactMessage {
  id        String    @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String
  read      Boolean   @default(false)
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([read, createdAt(sort: Desc)])
  @@map("contact_messages")
}

// ─── SITE SETTINGS ────────────────────────────────────────────────────────────
// Key-value runtime configuration. Admin edits through UI — no redeployment.
// Bounded EAV: fewer than 10 keys in v1, all simple strings (S5.9 justified denorm).
// updatedBy: accountability trail — which admin last changed each setting.

model SiteSettings {
  id          String    @id @default(cuid())
  key         String    @unique
  value       String
  description String?
  updatedAt   DateTime  @updatedAt @map("updated_at")
  updatedBy   String?   @map("updated_by")

  user User? @relation(fields: [updatedBy], references: [id], onDelete: SetNull)

  @@map("site_settings")
}

// ─── NOTIFICATION ─────────────────────────────────────────────────────────────
// Outbox queue — v2 ready. Rows inserted on booking/message events.
// v1: rows created but not processed (no sender configured).
// v2: background worker reads sentAt=null and dispatches via Resend/WATI.
// Loose coupling: payload JSONB carries entity reference (not a typed FK).

model Notification {
  id        String    @id @default(cuid())
  type      String
  channel   String
  recipient String
  payload   Json
  sentAt    DateTime? @map("sent_at")
  failedAt  DateTime? @map("failed_at")
  error     String?
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([createdAt(sort: Asc)])
  @@map("notifications")
}

// ─── AUDIT LOG ────────────────────────────────────────────────────────────────
// Immutable event log — every admin and system action recorded here.
// NEVER updated. NEVER deleted. Write-once by design (S2.62).
// No updated_at, no deleted_at — intentional exceptions to S5.10.
// entity_type + entity_id: polymorphic reference — VARCHAR pair, not typed FK.
// Rationale: audit logs must survive deletion of the records they reference.

model AuditLog {
  id         String      @id @default(cuid())
  action     AuditAction
  entityType String      @map("entity_type")
  entityId   String      @map("entity_id")
  userId     String?     @map("user_id")
  ipAddress  String?     @map("ip_address")
  userAgent  String?     @map("user_agent")
  metadata   Json?
  createdAt  DateTime    @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId, createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("audit_logs")
}
