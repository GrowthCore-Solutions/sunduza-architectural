// Sunduza Prisma Schema v1.1 — Groups 1+2+3
// Built with: Prisma 5 + SQLite (dev) · PostgreSQL (prod)
// Constitution-compliant: Database Constitution D1-D58

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── ADMIN ─────────────────────────────────────────────────────────────────

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // bcrypt hash
  name      String
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── BOOKING (Lead) ────────────────────────────────────────────────────────

model Booking {
  id          String   @id @default(cuid())
  name        String
  email       String
  phone       String
  service     String
  location    String
  description String
  meetingDate String
  budget      String?
  status      String   @default("new") // new | contacted | in_review | confirmed | completed | cancelled
  notes       String?  // admin notes
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── CONTACT MESSAGE ──────────────────────────────────────────────────────

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ─── PROJECT (Portfolio) ──────────────────────────────────────────────────

model Project {
  id              String   @id @default(cuid())
  title           String
  shortDescription String
  imageUrl        String
  category        String   // House Plan | Architectural Drawing | Drafting Services | Development Projects
  featured        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── TESTIMONIAL ─────────────────────────────────────────────────────────

model Testimonial {
  id         String   @id @default(cuid())
  clientName String
  review     String
  rating     Int      // 1-5
  featured   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
